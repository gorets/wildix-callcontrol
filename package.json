{
  "name": "@gorets/wildix-callcontrol",
  "version": "0.1.0",
  "description": "Headless SIP-based EventEmitter for parallel call control against a Wildix PBX",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "wildix",
    "sip",
    "pbx",
    "call-control",
    "telephony",
    "sip.js",
    "webrtc"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "predemo": "npm run build",
    "demo": "vite examples/dashboard --open",
    "prebuild:pages": "npm run build",
    "build:pages": "vite build examples/dashboard --outDir ../../site --emptyOutDir"
  },
  "peerDependencies": {
    "sip.js": "^0.21.2"
  },
  "dependencies": {
    "ltx": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "events": "^3.3.0",
    "jest": "^29.7.0",
    "sip.js": "0.21.2",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.1",
    "typescript": "^5.4.0",
    "vite": "^8.1.3"
  }
}
